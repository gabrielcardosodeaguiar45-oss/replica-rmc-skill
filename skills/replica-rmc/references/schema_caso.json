{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema do caso RMC/RCC — _analise.json",
  "description": "Estrutura produzida pelo subagent analisador-processo-rmc e consumida por consultor, redator e revisor. Campos obrigatórios sinalizados com required; ausências sempre null, nunca chute.",
  "type": "object",
  "required": ["autor", "processo", "banco", "contrato_principal", "_meta"],
  "properties": {
    "autor": {
      "type": "object",
      "required": ["nome", "cpf"],
      "properties": {
        "nome": {"type": "string"},
        "cpf": {"type": "string", "pattern": "^\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}$"},
        "rg": {"type": ["string", "null"]},
        "endereco": {"type": ["string", "null"]},
        "cidade": {"type": ["string", "null"]},
        "uf": {"type": ["string", "null"]},
        "genero": {"type": ["string", "null"], "enum": ["M", "F", null]},
        "data_nascimento": {"type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "idade": {"type": ["integer", "null"]},
        "beneficio_tipo": {"type": ["string", "null"], "description": "B31, B41, B52, BPC, etc."},
        "beneficio_numero": {"type": ["string", "null"]},
        "renda_mensal": {"type": ["number", "null"]},
        "hipossuficiente": {"type": "boolean", "default": true},
        "idoso_60mais": {"type": "boolean"},
        "escolaridade": {"type": ["string", "null"]}
      }
    },
    "processo": {
      "type": "object",
      "required": ["cnj"],
      "properties": {
        "cnj": {"type": "string", "pattern": "^\\d{7}-\\d{2}\\.\\d{4}\\.\\d\\.\\d{2}\\.\\d{4}$"},
        "cnj_resumido": {"type": "string"},
        "vara": {"type": ["string", "null"]},
        "comarca": {"type": "string"},
        "uf": {"type": "string", "enum": ["AM", "AL", "BA", "MG", "SC", "SP", "RJ", "PE", "CE", "PR", "GO", "MT", "MS", "RO", "AC", "RR", "AP", "PA", "MA", "PI", "RN", "PB", "TO", "ES", "DF"]},
        "data_inicial": {"type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "data_contestacao": {"type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "data_fim_prazo_replica": {"type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "tutela_pedida_na_inicial": {"type": "boolean", "default": false},
        "valor_causa": {"type": ["number", "null"]}
      }
    },
    "banco": {
      "type": "object",
      "required": ["razao_social"],
      "properties": {
        "razao_social": {"type": "string"},
        "cnpj": {"type": ["string", "null"]},
        "advogado_nome": {"type": ["string", "null"]},
        "advogado_oab": {"type": ["string", "null"]},
        "advogado_uf": {"type": ["string", "null"]},
        "escritorio": {"type": ["string", "null"]}
      }
    },
    "advogado_autor": {
      "type": "object",
      "properties": {
        "nome": {"type": "string"},
        "oab": {"type": "string"},
        "uf": {"type": "string"}
      }
    },
    "contrato_principal": {
      "type": "object",
      "required": ["tipo"],
      "properties": {
        "tipo": {"type": "string", "enum": ["RMC", "RCC"]},
        "numero": {"type": ["string", "null"]},
        "data_averbacao": {"type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "limite": {"type": ["number", "null"]},
        "parcela_media": {"type": ["number", "null"]},
        "terminacao_cartao": {"type": ["string", "null"]}
      }
    },
    "contrato_gemeo": {
      "type": "object",
      "properties": {
        "existe": {"type": "boolean", "default": false},
        "tipo": {"type": ["string", "null"], "enum": ["RMC", "RCC", null]},
        "numero": {"type": ["string", "null"]},
        "data_averbacao": {"type": ["string", "null"]},
        "atacado_na_inicial": {"type": "boolean", "default": false}
      }
    },
    "anexos_juntados_pelo_banco": {
      "type": "object",
      "properties": {
        "contrato_formal": {"type": "boolean"},
        "termo_adesao": {"type": "boolean"},
        "tce": {"type": "boolean"},
        "biometria": {"type": "boolean"},
        "selfie_liveness": {"type": "boolean"},
        "pedido_cartao": {"type": "boolean"},
        "carta_berco": {"type": "boolean"},
        "faturas": {"type": "boolean"},
        "faturas_2via_massiva": {"type": "boolean"},
        "faturas_data_postagem": {"type": ["string", "null"]},
        "teds": {"type": "boolean"},
        "procuracao": {"type": "boolean"},
        "laudo_digital": {"type": "boolean"},
        "hash": {"type": "boolean"},
        "geolocalizacao": {"type": "boolean"},
        "ip": {"type": ["string", "null"]},
        "id_sessao": {"type": "boolean"}
      }
    },
    "teds": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "data": {"type": ["string", "null"]},
          "valor": {"type": ["number", "null"]},
          "banco_destino": {"type": ["string", "null"]},
          "agencia_destino": {"type": ["string", "null"]},
          "conta_destino": {"type": ["string", "null"]},
          "conta_inss_do_autor": {"type": ["string", "null"]},
          "destino_igual_conta_inss": {"type": "boolean"}
        }
      }
    },
    "contestacao": {
      "type": "object",
      "properties": {
        "preliminares_levantadas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "rotulo_banco", "trecho_literal"],
            "properties": {
              "id": {"type": "string"},
              "rotulo_banco": {"type": "string"},
              "trecho_literal": {"type": "string", "minLength": 20, "description": "1 a 3 frases copiadas LITERALMENTE da contestação. Ipsis litteris. OBRIGATÓRIO. Sem trecho, o item é descartado."},
              "pagina_aprox": {"type": ["integer", "null"]}
            }
          }
        },
        "teses_meritorias": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "rotulo_banco", "trecho_literal"],
            "properties": {
              "id": {"type": "string"},
              "rotulo_banco": {"type": "string"},
              "trecho_literal": {"type": "string", "minLength": 20, "description": "1 a 3 frases copiadas LITERALMENTE da contestação. Ipsis litteris. OBRIGATÓRIO."},
              "pagina_aprox": {"type": ["integer", "null"]}
            }
          }
        },
        "pede_compensacao": {"type": "boolean"},
        "invoca_in_28_2008": {"type": "boolean"},
        "invoca_res_cnj_159_2024": {"type": "boolean"},
        "invoca_litigancia_predatoria": {"type": "boolean"},
        "menciona_videochamada_09_2023": {"type": "boolean"},
        "fatos_extraprocessuais_alegados": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["palavra_chave", "trecho_literal"],
            "properties": {
              "palavra_chave": {"type": "string"},
              "trecho_literal": {"type": "string"},
              "pagina": {"type": ["integer", "null"]}
            }
          }
        }
      }
    },
    "bloqueadores": {
      "type": "array",
      "description": "Sinais que exigem escalação humana antes da redação. Pipeline para se houver entrada com criticidade ALTA.",
      "items": {
        "type": "object",
        "required": ["id", "descricao", "criticidade", "acao_recomendada"],
        "properties": {
          "id": {"type": "string", "description": "litispendencia_cnj_especifico, oab_divergente_inicial_dje, prescricao_zona_limitrofe, banco_juntou_audio_video, autora_pediu_inexistencia_com_doc_robusta, valor_causa_simbolico, procuracao_data_posterior_inicial"},
          "descricao": {"type": "string"},
          "trecho_literal_que_motivou": {"type": ["string", "null"]},
          "pagina": {"type": ["integer", "null"]},
          "criticidade": {"type": "string", "enum": ["ALTA", "MEDIA"]},
          "acao_recomendada": {"type": "string"}
        }
      }
    },
    "observacoes_caso": {
      "type": "array",
      "description": "Campo livre para registrar peculiaridades do caso que não cabem nos campos fixos. Cada item é uma string curta com âncora ao trecho ou página quando possível.",
      "items": {"type": "string"}
    },
    "laudo_digital": {
      "type": "object",
      "properties": {
        "existe": {"type": "boolean"},
        "ip": {"type": ["string", "null"]},
        "ip_classe": {"type": ["string", "null"], "enum": ["publico", "privado", null]},
        "lat": {"type": ["number", "null"]},
        "lng": {"type": ["number", "null"]},
        "precisao_metros": {"type": ["integer", "null"]},
        "hash_sha256": {"type": ["string", "null"]},
        "hash_presente": {"type": "boolean"},
        "selfie_liveness_ieee_iso": {"type": "boolean"},
        "id_sessao": {"type": ["string", "null"]},
        "data_hora": {"type": ["string", "null"]}
      }
    },
    "faturas": {
      "type": "object",
      "properties": {
        "postagem_concentrada": {"type": "boolean"},
        "data_postagem_predominante": {"type": ["string", "null"]},
        "total_faturas": {"type": "integer"},
        "descontos_consolidados_mesmo_dia": {"type": "boolean"},
        "terminacao_cartao_faturas": {"type": ["string", "null"]},
        "refin_maquiador_detectado": {"type": "boolean"},
        "data_refin_maquiador": {"type": ["string", "null"]},
        "valor_refin_maquiador": {"type": ["number", "null"]}
      }
    },
    "inicial": {
      "type": "object",
      "properties": {
        "pedido_danos_morais": {"type": ["number", "null"]},
        "pedido_danos_temporais": {"type": ["number", "null"]},
        "pedido_restituicao_dobro": {"type": "boolean"},
        "causa_pedir_inexistencia": {"type": "boolean", "default": true},
        "ja_impugnou_contratacao_digital": {"type": "boolean"}
      }
    },
    "comprovante_residencia": {
      "type": "object",
      "properties": {
        "em_nome_do_autor": {"type": "boolean"},
        "em_nome_de_terceiro": {"type": "boolean"},
        "nome_do_terceiro": {"type": ["string", "null"]},
        "declaracao_coabitacao_nos_autos": {"type": "boolean"}
      }
    },
    "sinais_fraude": {
      "type": "object",
      "properties": {
        "dados_cadastrais_divergentes": {"type": "boolean"},
        "divergencias_lista": {"type": "array", "items": {"type": "string"}},
        "correspondente_bancario_cidade_distante": {"type": "boolean"},
        "cidade_correspondente": {"type": ["string", "null"]},
        "seguro_casado": {"type": "boolean"},
        "nome_seguradora": {"type": ["string", "null"]}
      }
    },
    "_meta": {
      "type": "object",
      "required": ["pasta_processo", "data_analise"],
      "properties": {
        "pasta_processo": {"type": "string"},
        "data_analise": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "arquivos_extraidos": {"type": "array", "items": {"type": "string"}},
        "campos_nao_encontrados": {"type": "array", "items": {"type": "string"}},
        "versao_schema": {"type": "string", "default": "1.0.0"}
      }
    }
  }
}
